{
  "schemaVersion": 1,
  "id": "pxignis",
  "version": "${version}",
  "name": "PxIgnis",
  "description": "Lua-scriptable roleplay command framework for Fabric servers.",
  "authors": [
    {
      "name": "PyXiion",
      "contact": {
        "email": "me@pyxiion.ru",
        "homepage": "https://pyxiion.ru"
      }
    }
  ],
  "contact": {
    "email": "ignis@pyxiion.ru",
    "homepage": "https://ignis.pyxiion.ru",
    "sources": "https://github.com/PyXiion/PxIgnis",
    "issues": "https://github.com/PyXiion/PxIgnis/issues"
  },
  "license": "LGPL-3.0",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "ru.pyxiion.ignis.PxIgnis"
      }
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}",
    "fabric-language-kotlin": ">=1.10.8+kotlin.1.9.0"
  },
  "accessWidener" : "pxignis.accesswidener",
  "mixins": [
    "pxignis.mixins.json"
  ]
}
